# ==============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION EXAMPLE (.env.example)
# Rename this file to '.env' and populate it with your actual credentials.
# Do NOT commit your final '.env' file to version control (Git).
# ==============================================================================


# Description: The exact name of the directory where your Oracle Cloud Autonomous Database wallet files are stored.
# Context: In your Python code, this maps to the root directory's hidden storage path: root/.secrets/<wallet_folder>
ORACLE_WALLET_FOLDER=your_wallet_folder_name_here


# Description: The user account name or database schema name you are authenticating with.
# Context: For cloud instances, this defaults to 'ADMIN' unless a custom schema user was specifically created.
DB_USER=your_database_username_here


# Description: The password corresponding to the database user provided in DB_USER.
DB_PASSWORD=your_database_password_here


# Description: The Data Source Name connection string alias.
# Context: Inside your wallet folder, there is a file called 'tnsnames.ora'. This contains predefined connection service aliases which typically end in '_high', '_medium', or '_low' (e.g., 'my_db_high'). You need to place that exact string name here.
WALLET_DSN=your_wallet_dsn_alias_here


# Description: The master wallet encryption password.
# Context: This is the secure password you generated or were given when you downloaded your instance credentials bundle (the Client Wallet zip archive) from the Oracle Cloud Console.
WALLET_PASSWORD=your_wallet_password_here